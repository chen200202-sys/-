import requests

API_KEY = "XXXX" #לציין פה את הKEY הרלוונטי
URL = "https://server.iac.ac.il/api/v1/studentapi/responses"
headers = {"Authorization": f"Bearer {API_KEY}"}

print("ברוך הבא אל הסוכן 'הטיפש' של עמיחי וחן")
print("על מנת לעצור ולסיים את השיחה תרשמו 'עצירה'")

messages = []

while True:
    user_query = input("\nאת/ה: ")
    if user_query.lower() == 'עצירה': break

    messages.append({"role": "user", "content": user_query})

    payload = {
        "model": "gpt-5-nano",
        "instructions": "עני בעברית ברורה.",
        "input": user_query,
        "tools": [{"type": "web_search"}],
        "reasoning": {"effort": "low"}
    }

    print("🔎 מחפש תשובה, תנו לי את הזמן שלי!")

    try:
        response = requests.post(URL, json=payload, headers=headers)
        if response.status_code == 200:
            result = response.json()

            # התיקון כאן: השרת שולח מילון שיש בו מפתח בשם 'output'
            output_list = result.get("output", [])
            final_text = ""

            for item in output_list:
                if isinstance(item, dict) and item.get("type") == "message":
                    for content_block in item.get("content", []):
                        if content_block.get("type") == "output_text":
                            final_text = content_block.get("text")

            if final_text:
                print(f"סוכן AI: {final_text}")
                messages.append({"role": "assistant", "content": final_text})
            else:
                # גיבוי: אם המבנה שוב השתנה, נדפיס הכל כדי לראות מה קרה
                print(f"סוכן AI (Raw): {result}")

            # הצגת המכסה מהמקום הנכון ב-JSON החדש
            quota = result.get("iac_quota_status", {})
            remaining = quota.get("tokens_used_daily", "לא ידוע")
            print(f"--- טוקנים שנוצלו היום: {remaining} ---")

        else:
            print(f"שגיאת שרת: {response.status_code}")
    except Exception as e:
        print(f"שגיאה: {e}")
