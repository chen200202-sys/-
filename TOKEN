import requests


url = "https://server.iac.ac.il/api/v1/studentapi/generate_key"


payload = {
    "id": "XXXXXXXX",        # תז לפורטל מכללה
    "password": "XXXXX"  # סיסמא לפורטל מכללה
}

print("שולח בקשת התחברות לשרת המכללה...")

response = requests.post(url, json=payload)

if response.status_code == 200:
    token = response.json().get("token")
    print("הצלחה! הנה הטוקן שלך (תעתיקי אותו למקום בטוח):")
    print(token)
else:
    print(f"שגיאה {response.status_code}: {response.text}")
